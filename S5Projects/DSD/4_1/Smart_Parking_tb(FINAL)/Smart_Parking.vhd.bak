library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity Smart_Parking is
port (
    clk : in std_logic; 
    reset : in std_logic; 
    mode_switch : in std_logic; 
    sensor_in : in std_logic;
    sensor_out : in std_logic;
    gate_switch : in std_logic; 
    final_gate_state : out std_logic;
    servo_pwm : out std_logic;
    spots_display : out std_logic_vector(6 downto 0) 
);
end Smart_Parking;

architecture Behavioral of Smart_Parking is
    signal spots : integer range 0 to 8 := 8;
    signal gate_state : std_logic := '0';

    -- Constants for timing
    constant MOVEMENT_DELAY : integer := 7500000; 
    constant PWM_PERIOD : integer := 1000000; -- 20ms period for 50MHz clock
    constant PWM_MIN : integer := 75000;  -- 1ms pulse
    constant PWM_MAX : integer := 125000; -- 2ms pulse
    
    signal delay_timer_in : integer range 0 to MOVEMENT_DELAY := 0;
    signal delay_timer_out : integer range 0 to MOVEMENT_DELAY := 0;
    signal pwm_counter : integer range 0 to PWM_PERIOD := 0;
    signal pwm_duty_cycle : integer range PWM_MIN to PWM_MAX := PWM_MIN;
    
    function seg_encode(digit : integer) return std_logic_vector is
    begin
        case digit is
            when 0 => return "1000000"; -- 0
            when 1 => return "1111001"; -- 1
            when 2 => return "0100100"; -- 2
            when 3 => return "0110000"; -- 3
            when 4 => return "0011001"; -- 4
            when 5 => return "0010010"; -- 5
            when 6 => return "0000010"; -- 6
            when 7 => return "1111000"; -- 7
            when 8 => return "0000000"; -- 8
            when others => return "1111111"; -- Off
        end case;
    end function;

begin
    -- Main state machine process
    process (clk, reset)
    begin
        if reset = '0' then
            -- Reset all signals to known values
            spots <= 8;
            gate_state <= '0';
            delay_timer_in <= 0;
            delay_timer_out <= 0;
            pwm_duty_cycle <= PWM_MIN; -- Start with gate closed
            final_gate_state <= '0';
            spots_display <= seg_encode(8); -- Show 8 spots available
            
        elsif rising_edge(clk) then
            -- Update timers
            if delay_timer_in > 0 then
                delay_timer_in <= delay_timer_in - 1;
            end if;
            
            if delay_timer_out > 0 then
                delay_timer_out <= delay_timer_out - 1;
            end if;
            
            if spots > 0 then
                -- Mode handling and gate control
                if mode_switch = '1' then -- Autonomous mode
                    if sensor_in = '0' and delay_timer_in = 0 and gate_state = '0' then 
                        -- Car approaches, open gate
                        gate_state <= '1';
                        pwm_duty_cycle <= PWM_MAX; -- Move servo to +90° (open position)
                        delay_timer_in <= MOVEMENT_DELAY;
                        
                    elsif sensor_out = '0' and gate_state = '1' and delay_timer_out = 0 then 
                        -- Car passes through, close gate
                        gate_state <= '0';
                        spots <= spots - 1;
                        pwm_duty_cycle <= PWM_MIN; -- Move servo to -90° (closed position)
                        delay_timer_out <= MOVEMENT_DELAY;
                    end if;
                    
                else -- Manual mode
                    if gate_switch = '1' and gate_state = '0' then
                        -- Open gate manually
                        gate_state <= '1';
                        pwm_duty_cycle <= PWM_MAX; -- Open position
                        
                    elsif gate_switch = '0' and gate_state = '1' then
                        -- Close gate manually
                        gate_state <= '0';
                        spots <= spots - 1;
                        pwm_duty_cycle <= PWM_MIN; -- Closed position
                    end if;
                end if;
                
                -- Update outputs
                final_gate_state <= gate_state;
                spots_display <= seg_encode(spots);
            else
                -- Parking is full
                final_gate_state <= '0';
                spots_display <= "1000000"; -- Show '0'
            end if;
        end if;
    end process;

    -- PWM Generator Process for Servo Control WITH RESET
    process (clk, reset)
    begin
        if reset = '0' then
            pwm_counter <= 0;
            servo_pwm <= '0';
        elsif rising_edge(clk) then
            if pwm_counter < PWM_PERIOD then
                pwm_counter <= pwm_counter + 1;
            else
                pwm_counter <= 0;
            end if;
            
            -- Generate PWM signal
            if pwm_counter < pwm_duty_cycle then
                servo_pwm <= '1';
            else
                servo_pwm <= '0';
            end if;
        end if;
    end process;

end Behavioral;