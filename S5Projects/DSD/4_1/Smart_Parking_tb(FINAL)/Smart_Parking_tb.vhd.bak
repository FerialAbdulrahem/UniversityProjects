library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;
entity Smart_Parking_tb is
end Smart_Parking_tb;
architecture testbench of Smart_Parking_tb is
-- Signals matching entity ports
signal clk : std_logic := '0';
signal reset : std_logic := '1'; -- Active low, start high
signal mode_switch : std_logic := '0';
signal sensor_in : std_logic := '1'; -- Active low, start high (no car)
signal sensor_out : std_logic := '1'; -- Active low, start high (no car)
signal gate_switch : std_logic := '0';
signal final_gate_state : std_logic;
signal servo_pwm : std_logic;
signal spots_display : std_logic_vector(6 downto 0);
-- Clock period for 50 MHz
constant clk_period : time := 20 ns;
-- Component declaration
component Smart_Parking
port (
clk : in std_logic;
reset : in std_logic;
mode_switch : in std_logic;
sensor_in : in std_logic;
sensor_out : in std_logic;
gate_switch : in std_logic;
final_gate_state : out std_logic;
servo_pwm : out std_logic;
spots_display : out std_logic_vector(6 downto 0)
);
end component;
begin
-- Instantiate the unit under test (UUT)
uut: Smart_Parking port map (
clk => clk,
reset => reset,
mode_switch => mode_switch,
sensor_in => sensor_in,
sensor_out => sensor_out,
gate_switch => gate_switch,
final_gate_state => final_gate_state,
servo_pwm => servo_pwm,
spots_display => spots_display
);
-- Clock generation process (standard loop)
clk_process: process
begin
clk <= '0';
wait for clk_period / 2;
clk <= '1';
wait for clk_period / 2;
end process clk_process;
-- Stimulus process: Test reset, autonomous mode, manual mode, and spots=0
stimulus: process
begin
-- Initial reset (active low)
reset <= '0';
wait for 100 ns;
reset <= '1';
wait for 100 ns;
-- Test Autonomous Mode: Car approaches and passes
mode_switch <= '1'; -- Autonomous
sensor_in <= '0'; -- Car approaches (active low)
wait for 200 ns; -- Allow gate to open
sensor_in <= '1'; -- Car no longer at in-sensor
wait for 200 ns;
sensor_out <= '0'; -- Car passes out-sensor
 -- Allow gate to close, spots decrement
sensor_out <= '1';
wait for 200 ns;
-- Test Manual Mode: Toggle gate
mode_switch <= '0'; -- Manual
gate_switch <= '1'; -- Open gate
wait for 200 ns;
gate_switch <= '0'; -- Close gate, spots decrement
wait for 200 ns;
-- Test Spots = 0: Gate should not open
mode_switch <= '1'; -- Back to autonomous
sensor_in <= '0'; -- Try to open, but spots=0
wait for 200 ns;
sensor_in <= '1';
wait for 200 ns;
-- End simulation
wait;
end process stimulus;
end testbench;
